# LLM
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_DRAFTER=claude-sonnet-4-6

# Embeddings — defaults to local sentence-transformers (no API key needed)
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DB / cache
DATABASE_URL=postgresql+asyncpg://emoti:emoti_dev_pwd@postgres:5432/emoti
REDIS_URL=redis://redis:6379/0

# Auth / security
API_KEY=demo-emoti-key-change-me
WEBHOOK_HMAC_SECRET=demo-hmac-secret-change-me

# Operator console login (issues JWT)
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=operator-demo-pwd

# Tenant
TENANT_ID=emoti

# Feature flags
AI_DRAFT_ENABLED=true
AI_REFUND_ESCALATION_ONLY=true
AUTO_REPLY_ENABLED=false

# Cost guards
DAILY_BUDGET_USD=5.00

# Outbound webhook (where drafts get pushed)
OUTBOUND_WEBHOOK_URL=
OUTBOUND_WEBHOOK_HMAC_SECRET=

# Telemetry
LOG_LEVEL=INFO
