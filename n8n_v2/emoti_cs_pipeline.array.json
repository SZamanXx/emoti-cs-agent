          200,
          400
        ],
        "webhookId": "emoti-ticket-hybrid"
      },
      {
        "parameters": {
          "language": "javaScript",
          "jsCode": "// Decode raw body, extract HMAC-related metadata + idempotency key + parsed payload.\n// rawBody=true means n8n hands us body bytes in binary.data.data (base64).\nconst item = $input.first();\nconst headers = (item.json && item.json.headers) || (item.headers) || {};\nconst sigHeader = headers['x-webhook-signature'] || headers['X-Webhook-Signature'] || '';\nconst idemHeader = headers['x-idempotency-key'] || headers['X-Idempotency-Key'] || '';\n\nlet rawBody = '';\nif (item.binary && item.binary.data && item.binary.data.data) {\n  rawBody = Buffer.from(item.binary.data.data, 'base64').toString('utf-8');\n} else if (typeof item.json.body === 'string') {\n  rawBody = item.json.body;\n} else if (item.json && item.json.body) {\n  rawBody = JSON.stringify(item.json.body);\n} else {\n  rawBody = JSON.stringify(item.json || {});\n}\n\nlet parsed = {};\ntry { parsed = JSON.parse(rawBody); } catch (e) { parsed = {}; }\n\n// Parse signature header: 't=<unix>,v1=<hex>'\nlet ts = '';\nlet sigValue = '';\nif (sigHeader) {\n  const parts = Object.fromEntries(\n    sigHeader.split(',').filter(p => p.includes('=')).map(p => {\n      const [k, ...v] = p.split('=');\n      return [k.trim(), v.join('=')];\n    })\n  );\n  ts = parts.t || '';\n  sigValue = parts.v1 || '';\n}\n\nconst hmacInput = ts && rawBody ? ts + '.' + rawBody : '';\nconst sigProvided = !!(ts && sigValue);\nconst idemKey = idemHeader || ('idem-' + (parsed.message_id || parsed.channel_thread_id || ts || Date.now()));\n\n// Flat fields for downstream nodes — avoids n8n expression quirks with nested $json.parsed.X\nreturn [{ json: {\n  ts,\n  sig_value: sigValue,\n  sig_provided: sigProvided,\n  hmac_input: hmacInput,\n  idem_key: idemKey,\n  source: parsed.source || 'cms',\n  body: parsed.body || '',\n  subject: parsed.subject || null,\n  channel_thread_id: parsed.channel_thread_id || null,\n  sender: parsed.sender || null,\n  language_hint: parsed.language_hint || 'pl'\n}}];"
        },
        "id": "decode-1",
        "name": "Decode + extract metadata",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          420,
          400
        ]
      },
      {
        "parameters": {
          "action": "hmac",
          "type": "SHA256",
          "value": "={{ $json.hmac_input }}",
          "secret": "={{ $env.EMOTI_HMAC_SECRET || 'demo-hmac-secret-change-me' }}",
          "encoding": "hex",
          "dataPropertyName": "hmac_computed"
        },
        "id": "crypto-1",
        "name": "Compute HMAC",
        "type": "n8n-nodes-base.crypto",
        "typeVersion": 1,
        "position": [
          640,
          400
        ]
      },
      {
        "parameters": {
          "language": "javaScript",
          "jsCode": "// Decide HMAC outcome:\n//  - if no signature header was sent → SKIP (demo-friendly, backend uses same fallback)\n//  - if signature is sent → must match computed HMAC; ts within 300s\nconst dec = $('Decode + extract metadata').first().json;\nconst computed = $json.hmac_computed || '';\nconst now = Math.floor(Date.now() / 1000);\nconst ageOk = !dec.ts ? false : Math.abs(now - parseInt(dec.ts, 10)) <= 300;\n\nlet outcome = 'pass';\nlet reason = '';\nif (!dec.sig_provided) {\n  outcome = 'skip';\n  reason = 'no signature header (demo mode — backend re-verifies)';\n} else if (!ageOk) {\n  outcome = 'fail';\n  reason = 'signature timestamp outside 300s window';\n} else if (computed.toLowerCase() !== (dec.sig_value || '').toLowerCase()) {\n  outcome = 'fail';\n  reason = 'signature mismatch';\n}\n\nreturn [{ json: {\n  ...dec,\n  hmac_computed: computed,\n  hmac_outcome: outcome,\n  hmac_reason: reason\n}}];"
        },
        "id": "hmac-check-1",
        "name": "HMAC verdict",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          860,
          400
        ]
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "strict"
            },
            "conditions": [
              {
                "id": "hmac-not-fail",
                "leftValue": "={{ $json.hmac_outcome }}",
                "rightValue": "fail",
                "operator": {
                  "type": "string",
                  "operation": "notEquals"
                }
              }
            ],
            "combinator": "and"
          },
          "options": {}
        },
        "id": "if-hmac-1",
        "name": "HMAC OK?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2,
