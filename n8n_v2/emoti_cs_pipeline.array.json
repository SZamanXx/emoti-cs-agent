      {
        "parameters": {
          "language": "javaScript",
          "jsCode": "// Pattern pre-filter — port of backend services/defense.py (English + Polish jailbreak markers).\nconst d = $json;\nconst text = (d.subject || '') + '\\n' + (d.body || '');\nconst patterns = [\n  ['ignore_previous',     /\\bignore\\s+(all\\s+)?(previous|prior|above)\\s+(instructions?|prompts?|rules?)\\b/i],\n  ['ignore_polish',       /\\b(zignoruj|ignoruj)\\s+(poprzednie|wszystkie)\\s+(instrukcje|polecenia|reguły)\\b/i],\n  ['you_are_now',         /\\byou\\s+are\\s+now\\s+/i],\n  ['act_as',              /\\b(act\\s+as|pretend\\s+to\\s+be|udawaj|zachowuj\\s+się\\s+jak)\\b/i],\n  ['system_role_marker',  /<\\|?\\s*system\\s*\\|?>|^\\s*system\\s*:\\s*/im],\n  ['override_directive',  /\\b(override|bypass|disregard|disable)\\s+(?:the\\s+|all\\s+|any\\s+)?(safety|restrictions?|filter|guardrails?)\\b/i],\n  ['reveal_prompt',       /\\b(reveal|show|repeat)\\s+(your\\s+)?(system\\s+)?(prompt|instructions)\\b/i],\n  ['ai_meta',             /\\bif\\s+you\\s+are\\s+(an?\\s+)?(ai|llm|language\\s+model)\\b/i]\n];\nconst signals = [];\nfor (const [label, re] of patterns) if (re.test(text)) signals.push(label);\nreturn [{ json: { ...d, _prefilter_signals: signals, _prefilter_suspected: signals.length > 0 } }];"
        },
